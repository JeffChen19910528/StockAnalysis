<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="F:\Users\Desktop\StockAnalysis\venv\Scripts\python.exe"
                  arguments="F:\Users\Desktop\StockAnalysis\run_waitress.py"
                  stdoutLogEnabled="true"
                  stdoutLogFile="F:\Users\Desktop\StockAnalysis\logs\stdout.log"
                  startupTimeLimit="60"
                  requestTimeout="00:04:00">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="ANTHROPIC_API_KEY" value="" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
